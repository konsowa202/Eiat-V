# Public Sanity project — used by the landing page pages to read content (services, offers, doctors…).
NEXT_PUBLIC_SANITY_PROJECT_ID=f46widyg
NEXT_PUBLIC_SANITY_DATASET=production

# Read token (optional, used for fresh reads server-side via @sanity/client).
SANITY_TOKEN=

# Gmail App Password (required on the *server* for contact / booking — not NEXT_PUBLIC_).
# Without these in production, Nodemailer returns: Missing credentials for "PLAIN".
# Hostinger: put in packages/eiat-site/.env and restart PM2. Vercel: Project → Settings → Environment Variables.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-16-char-app-password

NODE_ENV=production
