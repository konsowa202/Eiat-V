# Local dev: if this file is empty, keys can live in `packages/eiat-site/.env.local` — next.config.ts merges them (override: false).

# ================================
# Sanity
# ================================
NEXT_PUBLIC_SANITY_PROJECT_ID=f46widyg
NEXT_PUBLIC_SANITY_DATASET=production
# Write token (Editor role) — required on Vercel for:
# - /api/whatsapp/send and webhook to CREATE conversation rows (otherwise messages reach WhatsApp but not the Studio chat)
# - If missing or read-only, Sanity returns HTTP 403 on mutate.
# Create: https://www.sanity.io/manage → Project → API → Tokens
SANITY_API_WRITE_TOKEN=

# ================================
# WhatsApp Cloud API (Meta)
# ================================
# Even with full token permissions, Meta does not expose a Cloud API to "download" or list
# past customer inbound messages from their servers (inbound is delivered via webhooks only).
# This is a product/API design limit, not missing scopes on WHATSAPP_ACCESS_TOKEN.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=1067072803156944
WHATSAPP_BUSINESS_ACCOUNT_ID=495811770284793
WHATSAPP_VERIFY_TOKEN=eiat_webhook_2025

# Optional: NOT from Meta — your own long random secret so only you can call POST /api/whatsapp/replay-webhook
# (Studio «استعادة Webhook»). Same JSON shape as a real Meta webhook body, replayed into Sanity.
WHATSAPP_WEBHOOK_REPLAY_TOKEN=

# Re-engagement template (used by /api/whatsapp/send-media when conversation is outside 24h window)
WHATSAPP_REENGAGEMENT_TEMPLATE_NAME=appointment_confirmed
WHATSAPP_REENGAGEMENT_TEMPLATE_LANG=ar

# Legacy aliases (kept for back-compat)
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# ================================
# Studio → API origin (only needed when Studio is hosted on a different origin, e.g. sanity.studio)
# For a Next.js deployment where the Studio and /api share the same origin, leave empty.
# ================================
SANITY_STUDIO_WA_SITE_ORIGIN=
